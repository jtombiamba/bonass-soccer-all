# Backend .env.example - copy to .env and fill for local/production
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bonass_soccer
CELERY_BROKER_URL=redis://localhost:6379/0

# Email configuration - choose appropriate backend
# For development with MailHog (when DEBUG=True)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=mailhog
# EMAIL_PORT=1025
# EMAIL_USE_TLS=False

# For production SMTP (when DEBUG=False)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-username
# EMAIL_HOST_PASSWORD=your-password
# EMAIL_USE_TLS=True

# Default values (console backend - safe for local testing)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# Frontend base URL for poll links
FRONTEND_BASE_URL=http://localhost:3000
