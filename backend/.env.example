# Backend .env.example - copy to .env and fill for local/production
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bonass_soccer
CELERY_BROKER_URL=redis://localhost:6379/0

# Email configuration (console backend by default)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# Frontend base URL for poll links
FRONTEND_BASE_URL=http://localhost:3000
